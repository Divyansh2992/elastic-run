# ─────────────────────────────────────────────
# LogiSense Server — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# e.g. mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/logisense?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/logisense?retryWrites=true&w=majority

# Server port
PORT=5000

# Data tick interval in milliseconds (how often live data refreshes)
TICK_INTERVAL_MS=5000
